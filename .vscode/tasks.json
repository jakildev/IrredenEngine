{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Configure IRGame (from root)",
      "type": "shell",
      "command": "cmake",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "osx": {
        "args": [
          "--preset",
          "macos-debug"
        ]
      },
      "windows": {
        "args": [
          "--preset",
          "windows-debug"
        ]
      },
      "problemMatcher": []
    },
    {
      "label": "Build IRGame (from root)",
      "type": "shell",
      "command": "cmake",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "osx": {
        "args": [
          "--build",
          "build",
          "--target",
          "IRGame"
        ]
      },
      "windows": {
        "args": [
          "--build",
          "build",
          "--target",
          "IRGame"
        ]
      },
      "dependsOn": [
        "Configure IRGame (from root)"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Run IRGame (from root)",
      "type": "shell",
      "command": "cmake",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "osx": {
        "args": [
          "--build",
          "build",
          "--target",
          "IRGameRun"
        ]
      },
      "windows": {
        "args": [
          "--build",
          "build",
          "--target",
          "IRGameRun"
        ]
      },
      "dependsOn": [
        "Configure IRGame (from root)"
      ],
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}
