#!/usr/bin/env bash
# fleet-pr-amend-push — push the detached-HEAD amendment back to the
# PR's head ref. Sibling to fleet-pr-checkout-detached.
#
# Why this exists
# ---------------
# After `fleet-pr-checkout-detached <N>`, the worker is on detached
# HEAD pointing at `origin/<head-ref>`. The conventional `git push`
# (with no refspec) refuses to push a detached HEAD because there's
# no local branch name to map to. The right form is:
#
#     git push --force-with-lease origin HEAD:<head-ref>
#
# This wrapper reads the head ref name from the sentinel
# `.git/fleet-amend-ref` (written by fleet-pr-checkout-detached) and
# runs the push. On success it removes the sentinel so a subsequent
# `commit-and-push` invocation in the same worktree falls back to
# the normal (non-amend) flow.
#
# The `--force-with-lease` (vs plain `--force`) is the only safety
# belt against a concurrent amendment from another worktree (another
# worker, the merger mid-rebase, the operator pushing from the main
# clone). If the remote ref moved between fetch and push, the lease
# fails, the wrapper exits non-zero, and the caller's role retries
# on the next iteration.
#
# Usage
# -----
#   fleet-pr-amend-push
#
# Exit status:
#   0  push succeeded; sentinel removed
#   1  sentinel missing, push failed, or git in a bad state
#   2  usage error
#
# Source of truth: scripts/fleet/fleet-pr-amend-push in the engine
# repo. Installed to ~/bin/ by scripts/fleet/install.sh.

set -euo pipefail

if [[ $# -gt 0 ]]; then
    case "$1" in
        -h|--help)
            sed -n '2,38p' "$0" | sed 's/^# \{0,1\}//'
            exit 0
            ;;
        *)
            echo "fleet-pr-amend-push: takes no arguments" >&2
            exit 2
            ;;
    esac
fi

git_dir=$(git rev-parse --git-dir 2>/dev/null || true)
if [[ -z "$git_dir" ]]; then
    echo "fleet-pr-amend-push: not inside a git worktree" >&2
    exit 1
fi

# Worktree-scope guard (#2402): the push below runs from the cwd repo, and a
# stale amend-ref sentinel in a shared main clone would route it from the wrong
# tree. Refuse unless cwd is a fleet worktree. Resolve the sibling helper the
# same way the other fleet-* tools do; fall back to an inline structural check if
# it isn't linked yet (e.g. before install.sh has run).
guard="${BASH_SOURCE[0]}"
while [[ -L "$guard" ]]; do guard="$(readlink "$guard")"; done
guard="$(cd "$(dirname "$guard")" && pwd)/fleet-assert-worktree"
if [[ -x "$guard" ]]; then
    "$guard" || exit 1
else
    _tl=$(git rev-parse --show-toplevel 2>/dev/null || true)
    if [[ -n "$_tl" && "$_tl" != */.claude/worktrees/* && -z "${FLEET_ALLOW_MAIN_CLONE:-}" ]]; then
        echo "fleet-pr-amend-push: REFUSING — cwd ($_tl) is not a fleet worktree (#2402)." >&2
        echo "  cd into your worktree before pushing an amendment. Human override: FLEET_ALLOW_MAIN_CLONE=1" >&2
        exit 1
    fi
fi

sentinel="$git_dir/fleet-amend-ref"
if [[ ! -f "$sentinel" ]]; then
    echo "fleet-pr-amend-push: $sentinel missing — was fleet-pr-checkout-detached run in this worktree?" >&2
    exit 1
fi

# Sentinel is two lines: head ref (line 1) + checkout-time base SHA (line 2;
# absent on legacy sentinels written before the base-sha lease landed). The
# base SHA is what makes the lease safe — see the push below.
{ read -r head_ref; read -r base_sha; } < "$sentinel" 2>/dev/null || true
if [[ -z "$head_ref" ]]; then
    echo "fleet-pr-amend-push: sentinel $sentinel is empty" >&2
    exit 1
fi

# Defense against stale sentinels: refuse if HEAD isn't detached.
# A stale sentinel from a previous (abandoned) iteration would
# otherwise push the current branch's commits to the old PR's head
# ref. `git symbolic-ref -q HEAD` succeeds (exit 0) only on a named
# branch; on detached HEAD it exits non-zero.
if git symbolic-ref -q HEAD >/dev/null 2>&1; then
    branch=$(git rev-parse --abbrev-ref HEAD)
    echo "fleet-pr-amend-push: HEAD is on branch '$branch', not detached — sentinel may be stale" >&2
    echo "  expected: detached HEAD at origin/$head_ref (from fleet-pr-checkout-detached)" >&2
    echo "  if the sentinel is stale, remove it: rm $sentinel" >&2
    exit 1
fi

# Fast-forward fast path. Refresh the remote tip; if HEAD descends from it
# (the clean common case: detached checkout -> commit on top -> push, and a
# follow-up amend once the prior push became the tip), land it with a PLAIN
# push — no force, so it is not classifier-gated and there is nothing to
# clobber. `merge-base --is-ancestor` is robust to the fetch; the non-FF path
# below leases against the sentinel's base SHA, which the fetch can't refresh.
# (In the #1310 clobber, HEAD did NOT descend from the other worker's push, so
# this path is skipped and the lease-and-refuse below correctly fires.)
git fetch origin "$head_ref" >/dev/null 2>&1 || true
remote_tip=$(git rev-parse "origin/$head_ref" 2>/dev/null || echo "")
if [[ -n "$remote_tip" ]] && git merge-base --is-ancestor "$remote_tip" HEAD 2>/dev/null; then
    if ! git push origin "HEAD:$head_ref"; then
        echo "fleet-pr-amend-push: fast-forward push failed (remote rejected)." >&2
        exit 1
    fi
    rm -f "$sentinel"
    printf 'fleet-pr-amend-push: fast-forwarded origin/%s (no force needed)\n' "$head_ref"
    exit 0
fi

# Not a fast-forward — the amendment replaced commits. Force-with-lease pinned
# to the CHECKOUT-TIME base SHA, not the bare
# remote-tracking ref. A bare --force-with-lease leases against origin/<head_ref>,
# which an intervening `git fetch` refreshes to a concurrent agent's push — so
# the lease passes and clobbers their commit (the #1310 dual-worker clobber,
# 2026-05-29). Pinning the expected SHA makes the push REFUSE if origin/<head_ref>
# moved since checkout, full stop. (Quoting HEAD:$head_ref defensively in case a
# future fleet adopts head refs with shell-significant chars.)
if [[ -n "$base_sha" ]]; then
    lease="--force-with-lease=$head_ref:$base_sha"
else
    echo "fleet-pr-amend-push: sentinel has no base SHA (legacy checkout) — using a bare lease, which does NOT guard against an intervening fetch. Re-run fleet-pr-checkout-detached for full clobber protection." >&2
    lease="--force-with-lease"
fi
if ! git push "$lease" origin "HEAD:$head_ref"; then
    echo "fleet-pr-amend-push: push REFUSED — origin/$head_ref moved since you checked out (another agent pushed). Do NOT force past this: re-run fleet-pr-checkout-detached to re-base on their commit, re-apply your amendment, then push again." >&2
    exit 1
fi

# Clean up the sentinel so subsequent commit-and-push in this worktree
# falls back to the normal flow (or so a stale sentinel doesn't
# accidentally route a future commit to the wrong ref).
rm -f "$sentinel"

printf 'fleet-pr-amend-push: pushed HEAD to origin/%s\n' "$head_ref"
