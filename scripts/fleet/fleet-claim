    molecule)
        sub="${2:-}"
        if [[ -z "$sub" ]]; then
            echo "usage: fleet-claim molecule {list|show|resume|advance|complete|rebase-downstream} [args]" >&2
            exit 2
        fi
        case "$sub" in
            list)
                cmd_molecule_list
                ;;
            show)
                if [[ -z "${3:-}" ]]; then
                    echo "usage: fleet-claim molecule show <agent>" >&2
                    exit 2
                fi
                cmd_molecule_show "$3"
                ;;
