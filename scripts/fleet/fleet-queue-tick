#!/usr/bin/env bash
# fleet-queue-tick — run fleet-tasks-render --in-place and commit if dirty.
#
# Invoked directly by fleet-state-scout when the queue-manager projection
# changes (PR merge, issue close, etc.). No LLM involved — pure mechanical
# derived-field maintenance.
#
# Idempotent: exits 0 with no commit when TASKS.md is already current.
# Lockfile prevents concurrent runs. Push race is handled with rebase+retry.
#
# Source of truth: scripts/fleet/fleet-queue-tick in the engine repo.
# Installed to ~/bin/fleet-queue-tick by scripts/fleet/install.sh.

set -euo pipefail

ENGINE="${FLEET_ENGINE:-$HOME/src/IrredenEngine}"
GAME="$ENGINE/creations/game"
LOCK_DIR="${FLEET_QUEUE_TICK_LOCK:-$HOME/.fleet/state/queue-tick.lock}"
LOG_FILE="$HOME/.fleet/logs/queue-tick.log"

mkdir -p "$(dirname "$LOG_FILE")"

log() {
    printf '[%s queue-tick] %s\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" "$*" | tee -a "$LOG_FILE" >&2
}

# Directory-based lockfile (atomic on POSIX).
if ! mkdir "$LOCK_DIR" 2>/dev/null; then
    log "another fleet-queue-tick is running; exiting"
    exit 0
fi
trap 'rmdir "$LOCK_DIR" 2>/dev/null; true' EXIT INT TERM

log "starting"

# Use the queue-manager worktree as an isolated working area so we never
# touch the main clone's dirty state. Fall back to the main clone if the
# worktree hasn't been provisioned yet (e.g. first fleet-up after install).
QM_WT="$ENGINE/.claude/worktrees/queue-manager"
if [[ ! -d "$QM_WT" ]]; then
    log "queue-manager worktree not found; using main clone"
    QM_WT="$ENGINE"
fi

changed=0

# --- Engine TASKS.md ---
git -C "$QM_WT" fetch origin --quiet
# Reset to a clean state off master so we never carry stale branch commits.
git -C "$QM_WT" checkout -B fleet-queue-tick origin/master >/dev/null 2>&1
fleet-tasks-render --in-place "$QM_WT/TASKS.md"

if ! git -C "$QM_WT" diff --quiet -- TASKS.md; then
    changed=1
    git -C "$QM_WT" add TASKS.md
    # Include plan files if the renderer touched any.
    if ! git -C "$QM_WT" diff --quiet -- .fleet/plans/ 2>/dev/null; then
        git -C "$QM_WT" add .fleet/plans/
    fi
    git -C "$QM_WT" commit -m "queue: maintenance sync"
    # Push with rebase retry for concurrent master moves.
    for attempt in 1 2 3; do
        git -C "$QM_WT" fetch origin --quiet
        git -C "$QM_WT" rebase origin/master
        if git -C "$QM_WT" push origin HEAD:master; then
            log "engine TASKS.md pushed"
            break
        fi
        if [[ $attempt -lt 3 ]]; then
            log "push race (attempt $attempt) — retrying"
        else
            log "engine push failed after 3 attempts"
            exit 1
        fi
    done
fi

# --- Game TASKS.md (if present) ---
if [[ -d "$GAME/.git" ]]; then
    game_wt="$GAME/.claude/worktrees/queue-manager"
    [[ -d "$game_wt" ]] || game_wt="$GAME"
    git -C "$game_wt" fetch origin --quiet 2>/dev/null || true
    git -C "$game_wt" checkout -B fleet-queue-tick origin/master >/dev/null 2>&1 || true
    fleet-tasks-render --in-place --repo game "$game_wt/TASKS.md" 2>/dev/null || true
    if ! git -C "$game_wt" diff --quiet -- TASKS.md 2>/dev/null; then
        git -C "$game_wt" add TASKS.md
        git -C "$game_wt" commit -m "queue: maintenance sync"
        git -C "$game_wt" fetch origin --quiet || true
        git -C "$game_wt" rebase origin/master || true
        if git -C "$game_wt" push origin HEAD:master; then
            log "game TASKS.md pushed"
        else
            log "game push failed (non-fatal)"
        fi
        changed=1
    fi
fi

# --- Stale fleet:reviewing-* label sweep (T-217) ---
#
# Sweeps fleet:reviewing-<host>-<agent> labels older than 30 min off open
# PRs, then replays any orphan sentinels under ~/.fleet/orphans/ from
# earlier failed removals. Idempotent; safe under concurrent queue-tick
# invocations across hosts. Runs every tick (not gated on TASKS.md
# changes) — stale labels accumulate independently of TASKS.md churn.
fleet-claim cleanup --gh --repo jakildev/IrredenEngine >> "$LOG_FILE" 2>&1 || true

if [[ -d "$GAME/.git" ]]; then
    game_slug=$(git -C "$GAME" remote get-url origin 2>/dev/null \
        | sed -E 's|.*github.com[:/]||; s|\.git$||' || true)
    if [[ -n "$game_slug" ]]; then
        fleet-claim --repo game cleanup --gh --repo "$game_slug" >> "$LOG_FILE" 2>&1 || true
    fi
fi

if [[ $changed -eq 0 ]]; then
    log "TASKS.md unchanged — no commit"
else
    log "done"
fi
