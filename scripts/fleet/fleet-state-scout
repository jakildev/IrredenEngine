def _slice_pr_with_repo(repo_key, pr):
    out = dict(pr)
    out["repo"] = repo_key
    return out


def _slice_task_with_repo(repo_key, task):
    out = dict(task)
    out["repo"] = repo_key
    return out


def _slice_issue_with_repo(repo_key, issue):
    out = dict(issue)
    out["repo"] = repo_key
    return out


def slice_sonnet_author(state):
