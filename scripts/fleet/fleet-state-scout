# un-planned issues never hold the projection hash non-zero.
_INGEST_SKIP_LABELS = frozenset({
    "fleet:queued",        # pre-filtered by fetch_human_approved, included for explicitness
    "fleet:epic",
    "fleet:needs-plan",
    "fleet:needs-info",
