#!/usr/bin/env bash
# witness — fleet health monitor: polls agent heartbeats every 60 seconds
# and alerts when an agent's heartbeat goes stale.
#
# Each agent role writes a heartbeat to ~/.fleet/heartbeats/<agent-name>
# every loop iteration. Witness detects hung agents (alive process but
# stuck) by comparing the heartbeat file's mtime against a per-role
# staleness threshold.
#
# On staleness: logs to ~/.fleet/logs/witness.log and writes
# ~/.fleet/alerts/<agent>.stuck. Healthy agents have their alert files
# cleared automatically.
#
# Usage:
#   witness          run continuously (normal fleet pane mode)
#   witness --once   run one pass and exit (for testing/CI)
#
# Source of truth: scripts/fleet/witness in the engine repo.
# Installed to ~/bin/witness by scripts/fleet/install.sh.

set -euo pipefail

HEARTBEAT_DIR="$HOME/.fleet/heartbeats"
ALERT_DIR="$HOME/.fleet/alerts"
LOG_DIR="$HOME/.fleet/logs"
LOG="$LOG_DIR/witness.log"

mkdir -p "$HEARTBEAT_DIR" "$ALERT_DIR" "$LOG_DIR"

ONCE=0
for arg in "$@"; do
    case "$arg" in
        --once)      ONCE=1 ;;
        -h|--help)   sed -n '2,20p' "$0"; exit 0 ;;
        *) echo "witness: unknown argument '$arg'" >&2; exit 2 ;;
    esac
done

# Per-role staleness thresholds in seconds. Only architects are
# monitored — non-architect panes run under fleet-dispatcher (#273)
# and may sit idle for arbitrarily long when no triggers fire. The
# dispatcher's cleanup_stale_dispatches loop is the canonical
# aliveness check for those panes; witness alerts on workers would
# be false positives every quiet period.
#
# Architects use --resume sessions, may sit at "standing by" between
# human prompts. The 2 h threshold is generous enough for typical
# desk-time gaps without missing a genuine wedge.
threshold_for_agent() {
    case "$1" in
        opus-architect|game-architect)  echo 7200 ;;  # 2 h
        *)                              echo 0    ;;  # not monitored
    esac
}

# Portable file mtime in Unix seconds (macOS + Linux).
file_mtime() {
    python3 -c "import os, sys; print(int(os.path.getmtime(sys.argv[1])))" "$1"
}

run_one_pass() {
    local now_str now stale_count tracked
    now_str=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    now=$(date +%s)
    stale_count=0
    tracked=0

    for hb_file in "$HEARTBEAT_DIR"/*; do
        [[ -f "$hb_file" ]] || continue
        local agent threshold mtime age age_min thr_min msg
        agent=$(basename "$hb_file")
        threshold=$(threshold_for_agent "$agent")
        [[ "$threshold" -eq 0 ]] && continue
        tracked=$((tracked + 1))

        mtime=$(file_mtime "$hb_file")
        age=$((now - mtime))

        if [[ "$age" -gt "$threshold" ]]; then
            age_min=$((age / 60))
            thr_min=$((threshold / 60))
            stale_count=$((stale_count + 1))
            msg="STALE: $agent (last hb ${age_min}m ago, threshold ${thr_min}m)"
            echo "[$now_str witness] $msg" | tee -a "$LOG"
            echo "$now_str $agent age=${age_min}m threshold=${thr_min}m" > "$ALERT_DIR/$agent.stuck"
        else
            rm -f "$ALERT_DIR/$agent.stuck"
        fi
    done

    # fleet-dispatcher liveness check. The dispatcher is the canonical
    # aliveness signal for non-architect panes (#273 cutover); if it
    # crashes, those panes idle silently with no other alert path. The
    # PID file is written by fleet-up at launch and removed by the
    # dispatcher's own EXIT trap on clean shutdown.
    local dispatcher_pid_file="$HOME/.fleet/state/dispatcher.pid"
    if [[ -f "$dispatcher_pid_file" ]]; then
        local dispatcher_pid
        dispatcher_pid=$(cat "$dispatcher_pid_file" 2>/dev/null || true)
        if [[ -n "$dispatcher_pid" ]] && ! kill -0 "$dispatcher_pid" 2>/dev/null; then
            stale_count=$((stale_count + 1))
            local msg="STALE: fleet-dispatcher (pid $dispatcher_pid recorded but process is dead)"
            echo "[$now_str witness] $msg" | tee -a "$LOG"
            echo "$now_str dispatcher pid=$dispatcher_pid not running" > "$ALERT_DIR/fleet-dispatcher.stuck"
        else
            rm -f "$ALERT_DIR/fleet-dispatcher.stuck"
        fi
    fi

    if [[ "$stale_count" -eq 0 ]]; then
        echo "[$now_str witness] all healthy ($tracked agent(s) tracked)"
    fi
}

if [[ "$ONCE" -eq 1 ]]; then
    run_one_pass
    exit 0
fi

on_exit() {
    local rc=$?
    if [[ "$rc" -ne 0 ]]; then
        echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ) witness] unexpected exit (rc=$rc)" >> "$LOG"
    fi
}
on_signal() {
    trap - EXIT
    echo "[witness] shutting down"
    exit 0
}
trap on_exit EXIT
trap on_signal INT TERM

while true; do
    run_one_pass
    sleep 60
done
