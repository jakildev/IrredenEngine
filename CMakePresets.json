{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-debug",
      "displayName": "Windows Debug",
      "description": "Windows local configuration for development.",
      "generator": "MinGW Makefiles",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_POLICY_VERSION_MINIMUM": "3.5",
        "IRREDEN_GRAPHICS_BACKEND": "OPENGL"
      }
    },
    {
      "name": "macos-debug",
      "displayName": "macOS Debug",
      "description": "macOS local configuration for development.",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_POLICY_VERSION_MINIMUM": "3.5",
        "IRREDEN_GRAPHICS_BACKEND": "METAL"
      }
    },
    {
      "name": "linux-debug",
      "displayName": "Linux / WSL Debug",
      "description": "Linux and WSL2 local configuration for development. Target environment for the parallel-agent fleet.",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_POLICY_VERSION_MINIMUM": "3.5",
        "IRREDEN_GRAPHICS_BACKEND": "OPENGL",
        "CMAKE_C_COMPILER": "gcc-13",
        "CMAKE_CXX_COMPILER": "g++-13"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-build-all",
      "displayName": "Build All Targets",
      "configurePreset": "windows-debug"
    },
    {
      "name": "macos-build-all",
      "displayName": "Build All Targets (macOS)",
      "configurePreset": "macos-debug"
    },
    {
      "name": "linux-build-all",
      "displayName": "Build All Targets (Linux)",
      "configurePreset": "linux-debug"
    },
    {
      "name": "windows-format-check",
      "displayName": "Format Check",
      "configurePreset": "windows-debug",
      "targets": [
        "format-check"
      ]
    },
    {
      "name": "macos-format-check",
      "displayName": "Format Check (macOS)",
      "configurePreset": "macos-debug",
      "targets": [
        "format-check"
      ]
    },
    {
      "name": "linux-format-check",
      "displayName": "Format Check (Linux)",
      "configurePreset": "linux-debug",
      "targets": [
        "format-check"
      ]
    },
    {
      "name": "windows-format",
      "displayName": "Format",
      "configurePreset": "windows-debug",
      "targets": [
        "format"
      ]
    },
    {
      "name": "macos-format",
      "displayName": "Format (macOS)",
      "configurePreset": "macos-debug",
      "targets": [
        "format"
      ]
    },
    {
      "name": "linux-format",
      "displayName": "Format (Linux)",
      "configurePreset": "linux-debug",
      "targets": [
        "format"
      ]
    },
    {
      "name": "windows-lint",
      "displayName": "Lint",
      "configurePreset": "windows-debug",
      "targets": [
        "lint"
      ]
    },
    {
      "name": "macos-lint",
      "displayName": "Lint (macOS)",
      "configurePreset": "macos-debug",
      "targets": [
        "lint"
      ]
    },
    {
      "name": "linux-lint",
      "displayName": "Lint (Linux)",
      "configurePreset": "linux-debug",
      "targets": [
        "lint"
      ]
    },
    {
      "name": "windows-tests",
      "displayName": "Build Tests",
      "configurePreset": "windows-debug",
      "targets": [
        "IrredenEngineTest"
      ]
    },
    {
      "name": "macos-tests",
      "displayName": "Build Tests (macOS)",
      "configurePreset": "macos-debug",
      "targets": [
        "IrredenEngineTest"
      ]
    },
    {
      "name": "linux-tests",
      "displayName": "Build Tests (Linux)",
      "configurePreset": "linux-debug",
      "targets": [
        "IrredenEngineTest"
      ]
    }
  ],
  "testPresets": [
    {
      "name": "windows-default-tests",
      "displayName": "Run CTest (Windows)",
      "configurePreset": "windows-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "macos-default-tests",
      "displayName": "Run CTest (macOS)",
      "configurePreset": "macos-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "linux-default-tests",
      "displayName": "Run CTest (Linux)",
      "configurePreset": "linux-debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
