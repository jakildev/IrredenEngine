user.bazelrc
MODULE.bazel.lock
bazel-IrredenEngine/
bazel-bin/
bazel-out/
bazel-testlogs/

# local build and tooling output
build/
build-*/
cmake-build-*/
compile_commands.json
.cache/
CMakeUserPresets.json

# editor files: keep shareable config, ignore local state
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# OS / IDE noise
.DS_Store
Thumbs.db
.vs/
*.vcxproj.user

# fleet agent temp files
.review-body.md
.review-body-*.md
.pr-body.md
.merger-body.md
__pycache__/

# creations: keep demos, voxel editor scaffold, and top-level CLAUDE.md; ignore private tools
creations/*
!creations/CLAUDE.md
!creations/demos/
!creations/demos/**
!creations/editors/
creations/editors/font_maker
!creations/editors/voxel_editor/
!creations/editors/voxel_editor/**

# claude code: share skills + roles + path-scoped rules + worker subagents + project-level settings, ignore worktrees and per-session local state
.claude/*
!.claude/skills/
!.claude/skills/**
!.claude/commands/
!.claude/commands/**
!.claude/rules/
!.claude/rules/**
!.claude/agents/
!.claude/agents/**
!.claude/settings.json
